# Logs and databases
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE and editor files
.idea
.vscode
*.swp
*.swo
.DS_Store

# Rails specific
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore pidfiles, but keep the directory
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore master key for decrypting credentials
/config/master.key

# Cache
.eslintcache

.cursor/** */

.cursorrules

# Ignore all log files
/bgr4-api/log/*.log
/bgr4-api/log/development.log
/bgr4-api/log/test.log
/bgr4-api/log/production.log
/bgr4-api/log/dev

# Ignore large files
*.log
*.dump
*.gz
*.zip
*.tar
*.tar.gz
*.tgz
*.bz2
*.7z
*.rar

