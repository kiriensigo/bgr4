FROM ruby:3.3.0-slim

# 必要なパッケージをインストール（PostgreSQLクライアントを含む）
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 必要なGemfileを作成
RUN echo 'source "https://rubygems.org"' > Gemfile && \
    echo 'gem "sinatra"' >> Gemfile && \
    echo 'gem "sinatra-contrib"' >> Gemfile && \
    echo 'gem "puma"' >> Gemfile && \
    echo 'gem "pg"' >> Gemfile && \
    echo 'gem "sequel"' >> Gemfile && \
    echo 'gem "dotenv"' >> Gemfile && \
    echo 'gem "json"' >> Gemfile

# 依存関係のインストール
RUN gem install bundler && \
    bundle install

# アプリケーションファイルを作成
RUN mkdir -p /app/models /app/routes

# データベース接続設定
RUN echo 'require "sequel"' > /app/db.rb && \
    echo 'require "dotenv/load"' >> /app/db.rb && \
    echo 'require "logger"' >> /app/db.rb && \
    echo '' >> /app/db.rb && \
    echo 'module Database' >> /app/db.rb && \
    echo '  class << self' >> /app/db.rb && \
    echo '    def connection' >> /app/db.rb && \
    echo '      @connection ||= begin' >> /app/db.rb && \
    echo '        Sequel.connect(connection_string, logger: Logger.new($stdout))' >> /app/db.rb && \
    echo '      end' >> /app/db.rb && \
    echo '    end' >> /app/db.rb && \
    echo '' >> /app/db.rb && \
    echo '    def connection_string' >> /app/db.rb && \
    echo '      if ENV["INSTANCE_CONNECTION_NAME"] && ENV["DB_USER"] && ENV["DB_PASS"] && ENV["DB_NAME"]' >> /app/db.rb && \
    echo '        socket = ENV["INSTANCE_CONNECTION_NAME"]' >> /app/db.rb && \
    echo '        "postgres://#{ENV[\"DB_USER\"]}:#{ENV[\"DB_PASS\"]}@localhost/#{ENV[\"DB_NAME\"]}?host=/cloudsql/#{socket}"' >> /app/db.rb && \
    echo '      else' >> /app/db.rb && \
    echo '        "postgres://postgres:postgres@localhost/postgres"' >> /app/db.rb && \
    echo '      end' >> /app/db.rb && \
    echo '    end' >> /app/db.rb && \
    echo '  end' >> /app/db.rb && \
    echo 'end' >> /app/db.rb

# 簡単なゲームモデルを作成
RUN echo 'class Game' >> /app/models/game.rb && \
    echo '  attr_reader :id, :name, :description, :min_players, :max_players' >> /app/models/game.rb && \
    echo '' >> /app/models/game.rb && \
    echo '  def initialize(attributes)' >> /app/models/game.rb && \
    echo '    @id = attributes[:id]' >> /app/models/game.rb && \
    echo '    @name = attributes[:name]' >> /app/models/game.rb && \
    echo '    @description = attributes[:description]' >> /app/models/game.rb && \
    echo '    @min_players = attributes[:min_players]' >> /app/models/game.rb && \
    echo '    @max_players = attributes[:max_players]' >> /app/models/game.rb && \
    echo '  end' >> /app/models/game.rb && \
    echo '' >> /app/models/game.rb && \
    echo '  def self.all' >> /app/models/game.rb && \
    echo '    Database.connection[:games].all.map { |g| new(g) }' >> /app/models/game.rb && \
    echo '  end' >> /app/models/game.rb && \
    echo '' >> /app/models/game.rb && \
    echo '  def self.find(id)' >> /app/models/game.rb && \
    echo '    game = Database.connection[:games].where(id: id).first' >> /app/models/game.rb && \
    echo '    game ? new(game) : nil' >> /app/models/game.rb && \
    echo '  end' >> /app/models/game.rb && \
    echo '' >> /app/models/game.rb && \
    echo '  def to_json(*)' >> /app/models/game.rb && \
    echo '    {' >> /app/models/game.rb && \
    echo '      id: id,' >> /app/models/game.rb && \
    echo '      name: name,' >> /app/models/game.rb && \
    echo '      description: description,' >> /app/models/game.rb && \
    echo '      min_players: min_players,' >> /app/models/game.rb && \
    echo '      max_players: max_players' >> /app/models/game.rb && \
    echo '    }.to_json' >> /app/models/game.rb && \
    echo '  end' >> /app/models/game.rb && \
    echo 'end' >> /app/models/game.rb

# ゲームルートを作成
RUN echo 'class GameRoutes < Sinatra::Base' >> /app/routes/games.rb && \
    echo '  get "/games" do' >> /app/routes/games.rb && \
    echo '    content_type :json' >> /app/routes/games.rb && \
    echo '    Game.all.to_json' >> /app/routes/games.rb && \
    echo '  end' >> /app/routes/games.rb && \
    echo '' >> /app/routes/games.rb && \
    echo '  get "/games/:id" do' >> /app/routes/games.rb && \
    echo '    content_type :json' >> /app/routes/games.rb && \
    echo '    game = Game.find(params[:id])' >> /app/routes/games.rb && \
    echo '    if game' >> /app/routes/games.rb && \
    echo '      game.to_json' >> /app/routes/games.rb && \
    echo '    else' >> /app/routes/games.rb && \
    echo '      status 404' >> /app/routes/games.rb && \
    echo '      { error: "Game not found" }.to_json' >> /app/routes/games.rb && \
    echo '    end' >> /app/routes/games.rb && \
    echo '  end' >> /app/routes/games.rb && \
    echo 'end' >> /app/routes/games.rb

# メインアプリケーションファイルを作成
RUN echo 'require "sinatra/base"' > /app/app.rb && \
    echo 'require "sinatra/json"' >> /app/app.rb && \
    echo 'require "json"' >> /app/app.rb && \
    echo 'require_relative "db"' >> /app/app.rb && \
    echo 'require_relative "models/game"' >> /app/app.rb && \
    echo 'require_relative "routes/games"' >> /app/app.rb && \
    echo '' >> /app/app.rb && \
    echo 'class App < Sinatra::Base' >> /app/app.rb && \
    echo '  set :bind, "0.0.0.0"' >> /app/app.rb && \
    echo '  set :protection, false' >> /app/app.rb && \
    echo '' >> /app/app.rb && \
    echo '  get "/health" do' >> /app/app.rb && \
    echo '    content_type :json' >> /app/app.rb && \
    echo '    begin' >> /app/app.rb && \
    echo '      # データベース接続をテスト' >> /app/app.rb && \
    echo '      Database.connection.test_connection' >> /app/app.rb && \
    echo '      { status: "ok", database: "connected" }.to_json' >> /app/app.rb && \
    echo '    rescue => e' >> /app/app.rb && \
    echo '      status 500' >> /app/app.rb && \
    echo '      { status: "error", message: e.message }.to_json' >> /app/app.rb && \
    echo '    end' >> /app/app.rb && \
    echo '  end' >> /app/app.rb && \
    echo '' >> /app/app.rb && \
    echo '  get "/" do' >> /app/app.rb && \
    echo '    content_type :json' >> /app/app.rb && \
    echo '    { message: "Welcome to BGr4 API with Database!" }.to_json' >> /app/app.rb && \
    echo '  end' >> /app/app.rb && \
    echo '' >> /app/app.rb && \
    echo '  # マイグレーション用のエンドポイント（開発環境のみで使用）' >> /app/app.rb && \
    echo '  get "/setup-db" do' >> /app/app.rb && \
    echo '    return 403 unless ENV["RACK_ENV"] == "development"' >> /app/app.rb && \
    echo '    content_type :json' >> /app/app.rb && \
    echo '    db = Database.connection' >> /app/app.rb && \
    echo '    unless db.table_exists?(:games)' >> /app/app.rb && \
    echo '      db.create_table :games do' >> /app/app.rb && \
    echo '        primary_key :id' >> /app/app.rb && \
    echo '        String :name, null: false' >> /app/app.rb && \
    echo '        String :description, text: true' >> /app/app.rb && \
    echo '        Integer :min_players' >> /app/app.rb && \
    echo '        Integer :max_players' >> /app/app.rb && \
    echo '        DateTime :created_at' >> /app/app.rb && \
    echo '        DateTime :updated_at' >> /app/app.rb && \
    echo '      end' >> /app/app.rb && \
    echo '      # サンプルデータを挿入' >> /app/app.rb && \
    echo '      db[:games].insert(' >> /app/app.rb && \
    echo '        name: "カタン",  ' >> /app/app.rb && \
    echo '        description: "資源を集めて開拓するボードゲーム", ' >> /app/app.rb && \
    echo '        min_players: 3, ' >> /app/app.rb && \
    echo '        max_players: 4, ' >> /app/app.rb && \
    echo '        created_at: Time.now, ' >> /app/app.rb && \
    echo '        updated_at: Time.now' >> /app/app.rb && \
    echo '      )' >> /app/app.rb && \
    echo '      db[:games].insert(' >> /app/app.rb && \
    echo '        name: "ドミニオン", ' >> /app/app.rb && \
    echo '        description: "デッキ構築型カードゲーム", ' >> /app/app.rb && \
    echo '        min_players: 2, ' >> /app/app.rb && \
    echo '        max_players: 4, ' >> /app/app.rb && \
    echo '        created_at: Time.now, ' >> /app/app.rb && \
    echo '        updated_at: Time.now' >> /app/app.rb && \
    echo '      )' >> /app/app.rb && \
    echo '      { status: "Database setup completed" }.to_json' >> /app/app.rb && \
    echo '    else' >> /app/app.rb && \
    echo '      { status: "Database already exists" }.to_json' >> /app/app.rb && \
    echo '    end' >> /app/app.rb && \
    echo '  end' >> /app/app.rb && \
    echo '' >> /app/app.rb && \
    echo '  use GameRoutes' >> /app/app.rb && \
    echo 'end' >> /app/app.rb

# config.ruファイルを作成
RUN echo 'require "./app"' > /app/config.ru && \
    echo 'run App' >> /app/config.ru

# スタートアップスクリプトを作成
RUN echo '#!/bin/bash' > /app/start.sh && \
    echo 'echo "Starting BGr4 API with Database on port ${PORT:-8080}"' >> /app/start.sh && \
    echo 'echo "Database connection: $INSTANCE_CONNECTION_NAME"' >> /app/start.sh && \
    echo 'exec bundle exec puma -b tcp://0.0.0.0:${PORT:-8080} -e ${RACK_ENV:-production} config.ru' >> /app/start.sh && \
    chmod +x /app/start.sh

# .envファイルのサンプルを作成
RUN echo '# データベース接続情報' > /app/.env.sample && \
    echo 'DB_USER=postgres' >> /app/.env.sample && \
    echo 'DB_PASS=your_password' >> /app/.env.sample && \
    echo 'DB_NAME=bgr4_db' >> /app/.env.sample && \
    echo 'INSTANCE_CONNECTION_NAME=your-project:region:instance' >> /app/.env.sample && \
    echo 'RACK_ENV=development' >> /app/.env.sample

EXPOSE 8080

CMD ["./start.sh"] 