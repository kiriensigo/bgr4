RUN echo '        }, status: :created' >> app/controllers/api/v1/reviews_controller.rb
RUN echo '      end' >> app/controllers/api/v1/reviews_controller.rb
RUN echo '    end' >> app/controllers/api/v1/reviews_controller.rb
RUN echo '  end' >> app/controllers/api/v1/reviews_controller.rb
RUN echo 'end' >> app/controllers/api/v1/reviews_controller.rb

